diff --git a/src/memory/serializableMappingCache.native.ts b/src/memory/serializableMappingCache.native.ts
--- a/src/memory/serializableMappingCache.native.ts
+++ b/src/memory/serializableMappingCache.native.ts
@@ -21,11 +21,35 @@
 For convenience we moved this cache to a separate file so it doesn't scare us with red squiggles.
 */
 
-const cache = new WeakMap<object, SerializableRef | symbol>();
+// LEAK FIX (targeted): store the holder WEAKLY only when `weak` is requested —
+// i.e. for remote-function holders and worklet holders. Those are what made
+// __remoteFunctionRegistry immortal: the registry strong-holds the callback (key),
+// and a strong WeakMap VALUE then pinned the holder (whose NativeState owns the
+// shared_ptr<SerializableRemoteFunction> that gates registry.delete). A WeakRef
+// value lets the holder be collected, so the destructor runs and the entry frees.
+// Re-serializing a function/worklet is harmless (stateless equivalents).
+//
+// Everything else (shared values / Mutables, host objects, plain objects) stays
+// STRONG, as before — those rely on the cache to dedup to ONE serialized handle
+// (see the Shared Value note above). Weakening them caused stale reactive state.
+const cache = new WeakMap<object, SerializableRef | WeakRef<object> | symbol>();
 
 export const serializableMappingCache = {
-  set(serializable: object, serializableRef?: SerializableRef): void {
-    cache.set(serializable, serializableRef || serializableMappingFlag);
+  set(serializable: object, serializableRef?: SerializableRef, weak?: boolean): void {
+    if (!serializableRef) {
+      cache.set(serializable, serializableMappingFlag);
+      return;
+    }
+    cache.set(serializable, weak ? new WeakRef(serializableRef as object) : serializableRef);
   },
-  get: cache.get.bind(cache),
+  get(serializable: object): SerializableRef | symbol | undefined {
+    const entry = cache.get(serializable);
+    if (entry === undefined || entry === serializableMappingFlag) {
+      return entry as symbol | undefined;
+    }
+    if (entry instanceof WeakRef) {
+      return entry.deref() as SerializableRef | undefined;
+    }
+    return entry as SerializableRef;
+  },
 };
